// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  name     String
  gender   String
  avatarId String

  avatar        Avatar         @relation(fields: [avatarId], references: [id])
  spaceElements SpaceElement[]
}

model Avatar {
  id       String @id @default(cuid())
  name     String
  gender   String
  idleUrl  String
  leftUrl  String
  rightUrl String
  upUrl    String
  downUrl  String

  users User[]
}

model Space {
  id          String @id @default(cuid())
  name        String
  width       Int
  height      Int
  tilemapUrl  String                    // R2 object key -> Phaser Tiled JSON
  thumbnail   String                    // R2 object key -> dashboard preview

  elements      Element[]
  spaceElements SpaceElement[]
}

model Element {
  id           String  @id @default(cuid())
  spaceId      String
  name         String
  width        Int
  height       Int
  isCollidable Boolean @default(false)
  imageUrl     String                     // R2 object key for sprite of the element

  space         Space          @relation(fields: [spaceId], references: [id])
  spaceElements SpaceElement[]
}

model SpaceElement {
  id        String @id @default(cuid())
  elementId String
  spaceId   String
  addedById String
  x         Int
  y         Int

  space     Space   @relation(fields: [spaceId], references: [id])
  element   Element @relation(fields: [elementId], references: [id])
  addedBy   User    @relation(fields: [addedById], references: [id])
}